# ============================================
# UNIFIED .gitignore for AI-Agent SSH & Troubleshooting
# ============================================

# ---------- BACKEND (Python) ----------
# Secrets & environment
.env
.env.local
.env.*.local
!.env.example

# Runtime data — never commit user data
backend/system_store.json
backend/keys_index.json
backend/data/
backend/enable_auth.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
env/
ENV/
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/

# Database (if using SQLite)
*.db
*.sqlite
*.sqlite3

# ---------- FRONTEND (Node.js) ----------
# Dependencies
node_modules/
yarn.lock
pnpm-lock.yaml

# Production
dist/
build/
out/

# Environment
.env
.env.local
.env.*.local

# Vite
.vite/
*.local

# ---------- COMMON ----------
# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Deployment
deploy/nginx.conf  # Generated config
deploy/*.service   # Generated service files

# Test coverage
coverage/
.nyc_output/

# Misc
*.pid
*.seed
*.pid.lock

# Project specific
backend/logs/
frontend/.env*
backend/.env*
!backend/.env.example
.claude/

# Docker
docker-compose.override.yml
.dockerignore

# Backup files
*.backup
*.old
*.orig

# ============================================
# DO NOT COMMIT USER-GENERATED CONTENT
# ============================================
# SSH keys, logs, databases, and environment
# should never be committed to version control
