# ─────────────────────────────────────────────────────────────────────────────
# SSH Troubleshooting AI Agent — Environment Configuration
# Copy this file to .env and fill in the values you need.
# API keys are now managed via the Models page in the UI (stored encrypted in DB).
# Only GROQ_API_KEY here is a fallback for the default Groq provider.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (legacy fallback for Groq only — use the Models page instead) ─────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3

# ── SSH ────────────────────────────────────────────────────────────────────────
DEFAULT_SSH_TIMEOUT=30
MAX_CONCURRENT_SSH_CONNECTIONS=5

# ── API server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
API_TITLE=SSH Troubleshooting AI Agent
API_VERSION=1.0.0
ENABLE_API_DOCS=false

# Public base URL used to build SSH setup script download links.
# Set this to your server's public URL (e.g. https://myserver.example.com).
# Leave empty to auto-detect from request headers.
PUBLIC_BASE_URL=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Add your frontend domain in production (e.g. https://myapp.example.com).
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ── Database ───────────────────────────────────────────────────────────────────
# Leave empty to use the default local SQLite database (data/app.db).
# For PostgreSQL: postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=

# Memory backend:
# - local: SQLite-backed memory only
# - honcho: Honcho memory with local fallback
# - hybrid: write/retrieve from both Honcho and local SQLite
MEMORY_ENABLED=true
MEMORY_PROVIDER=local
MEMORY_CONTEXT_TOKENS=2500
MEMORY_MAINTENANCE_INTERVAL_DAYS=7
MEMORY_SUMMARY_AFTER_DAYS=30
MEMORY_MAX_LOCAL_RECORDS=5000
MEMORY_USER_PEER_ID=operator
MEMORY_ASSISTANT_PEER_ID=sshagent

# Honcho memory. Required only when MEMORY_PROVIDER=honcho or hybrid.
HONCHO_API_KEY=
HONCHO_WORKSPACE_ID=infra-agent
HONCHO_ENVIRONMENT=production
HONCHO_BASE_URL=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Number of days to retain app_logs entries. Older entries are purged on startup.
LOG_RETENTION_DAYS=30

# ── Security ───────────────────────────────────────────────────────────────────
# First-boot only. Once auth_settings exists in the DB, the DB value wins.
AUTH_ENABLED_BY_DEFAULT=false
ENABLE_COMMAND_VALIDATION=true
